{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "types": ["vite/client"]
  },
  "include": ["functions/**/*.ts", "abi/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
